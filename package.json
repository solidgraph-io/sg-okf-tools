{
  "name": "@solidgraph-io/okf-tools",
  "version": "0.1.0",
  "description": "CLI + library for Open Knowledge Format (OKF) knowledge bundles: conformance checking, progressive-disclosure indexes and a cross-link codemod. Config-driven, zero assumptions about your repo layout.",
  "type": "module",
  "license": "MIT",
  "author": "SolidGraph Solutions LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solidgraph-io/sg-okf-tools.git"
  },
  "keywords": [
    "okf",
    "open-knowledge-format",
    "knowledge-bundle",
    "markdown",
    "frontmatter",
    "docs",
    "documentation",
    "cli"
  ],
  "bin": {
    "okf": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
